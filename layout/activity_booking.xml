<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@android:color/white"
    android:padding="16dp">

    <!-- Title -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Booking Page"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="@color/design_default_color_primary"
        android:layout_marginBottom="24dp"/>

    <!-- Hall Name -->
    <TextView
        android:id="@+id/tvBookingHallName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Dewan Seri Utama"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp"/>

    <!-- Slot 1 -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardSlot1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        app:cardCornerRadius="8dp"
        app:cardElevation="2dp"
        android:foreground="?android:attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="SLOT 1"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/design_default_color_primary"/>

            <TextView
                android:id="@+id/tvSlot1DateTime"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="📅 Saturday, 15 March 2026 • 10:00 AM - 1:00 PM"
                android:textSize="14sp"
                android:layout_marginTop="4dp"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Slot 2 -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardSlot2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        app:cardCornerRadius="8dp"
        app:cardElevation="2dp"
        android:foreground="?android:attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="SLOT 2"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/design_default_color_primary"/>

            <TextView
                android:id="@+id/tvSlot2DateTime"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="📅 Saturday, 15 March 2026 • 2:00 PM - 5:00 PM"
                android:textSize="14sp"
                android:layout_marginTop="4dp"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Slot 3 -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardSlot3"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        app:cardCornerRadius="8dp"
        app:cardElevation="2dp"
        android:foreground="?android:attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="SLOT 3"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/design_default_color_primary"/>

            <TextView
                android:id="@+id/tvSlot3DateTime"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="📅 Sunday, 16 March 2026 • 10:00 AM - 1:00 PM"
                android:textSize="14sp"
                android:layout_marginTop="4dp"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Proceed Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnProceed"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="PROCEED"
        android:textSize="16sp"
        android:textAllCaps="true"
        app:cornerRadius="8dp"
        android:enabled="false"/>

</LinearLayout>